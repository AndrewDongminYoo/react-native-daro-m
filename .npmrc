# Resolve packages under the @dongminyu scope from GitHub Packages.
# The fork of react-native-daro-m (the one consumed for the tracking issue native fixes)
# is published there, not to the public npm registry.
@dongminyu:registry=https://npm.pkg.github.com

# Auth token, read from the local environment at install time.
# Local dev:  export PACKAGES_TOKEN=$(gh auth token)
# CI:         use the `GITHUB_TOKEN` provided by `actions/setup-node` with
#             `registry-url: https://npm.pkg.github.com` and
#             `scope: @dongminyu`, which exports PACKAGES_TOKEN.
//npm.pkg.github.com/:_authToken=${PACKAGES_TOKEN}

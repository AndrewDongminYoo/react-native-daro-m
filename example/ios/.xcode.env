# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
#
# Customize the NODE_BINARY variable here.
# For example, to use nvm with brew, add the following line
# . "$(brew --prefix nvm)/nvm.sh" --no-use
export NODE_BINARY=$(command -v node)

# New Architecture is enabled by default in React Native 0.85+. We set the
# flag explicitly so the posture is visible to anyone reading this file and
# so the example matches `android/gradle.properties` (`newArchEnabled=true`).
# This validates ADR-005 — the legacy bridge in src/ should keep working via
# the New Architecture interop layer without any TurboModule/Fabric rewrites.
export RCT_NEW_ARCH_ENABLED=1
